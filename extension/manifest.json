{
  "manifest_version": 3,
  "name": "YT Chat — AI Video Assistant",
  "version": "1.0.0",
  "description": "Chat with any YouTube video using AI. Ask questions, get instant answers from video transcripts.",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "*://*.youtube.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"],
      "css": [],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "YT Chat — AI Video Assistant"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["panel.html", "styles.css", "panel.js", "icons/*"],
      "matches": ["*://*.youtube.com/*"]
    }
  ]
}
